# HTTP 服务端口
PORT=8888

# API Key（浏览器注入脚本需要使用）
API_KEY=your-secret-api-key-change-this

# tmux 会话名称
TMUX_SESSION=goofish-agent

# Claude 命令路径
CLAUDE_PATH=/usr/local/bin/claude

# 工作目录
WORK_DIR=/path/to/goofish-agent/sales-agent

# 初始化指令
INIT_COMMAND=/goofish-init

# 日志级别: debug, info, warn, error
LOG_LEVEL=info

# 消息处理超时时间（毫秒）
MESSAGE_TIMEOUT=300000
