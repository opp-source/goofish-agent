# 云端 Worker 地址
CLOUD_WORKER_URL=https://your-worker.your-subdomain.workers.dev

# API Key（与 Worker 配置一致）
API_KEY=your-secret-api-key-change-this

# tmux 会话名称
TMUX_SESSION=goofish-agent

# Claude 命令路径
CLAUDE_PATH=/usr/local/bin/claude

# 工作目录
WORK_DIR=/Users/wenguoyin/Public/goofish-agent/sales-agent

# 初始化指令
INIT_COMMAND=/goofish-init

# 日志级别: debug, info, warn, error
LOG_LEVEL=info

# 消息处理超时时间（毫秒）
MESSAGE_TIMEOUT=300000
